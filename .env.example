# PM Tool 环境变量配置
# 
# 本地使用（默认）：
#   不设置 DATABASE_URL，自动使用本地 SQLite 数据库
#   数据存储在本机，不上传到云端
#
# 云端同步（你自己的机器）：
#   设置 DATABASE_URL 为 Turso libsql 地址
#   DATABASE_URL=libsql://your-db.turso.io?authToken=your-token

DEEPSEEK_API_KEY=
# 如需 AI 周报功能，请填入 DeepSeek API Key
# 获取地址: https://platform.deepseek.com/api_keys
